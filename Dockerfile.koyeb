FROM koyeb/docker-compose

# Alpine-пакеты
RUN apk add --no-cache python3 py3-pip make ca-certificates bash

# Отдельное venv для Python-инструментов
RUN python3 -m venv /opt/venv \
 && /opt/venv/bin/pip install --upgrade pip \
 && /opt/venv/bin/pip install --no-cache-dir langgraph-cli

# чтобы 'langgraph' был в PATH
ENV PATH="/opt/venv/bin:$PATH"

WORKDIR /app
COPY . /app

COPY ops/koyeb-run.sh /koyeb-run.sh
RUN chmod +x /koyeb-run.sh

CMD ["/koyeb-run.sh"]
