FROM koyeb/docker-compose

# Устанавливаем зависимости в Alpine
RUN apk add --no-cache python3 py3-pip make ca-certificates

# CLI langgraph для make build_graph
RUN pip3 install --no-cache-dir langgraph-cli

WORKDIR /app
COPY . /app

COPY ops/koyeb-run.sh /koyeb-run.sh
RUN chmod +x /koyeb-run.sh

# Базовый entrypoint образа стартует dockerd; затем выполняется наш CMD
CMD ["/koyeb-run.sh"]
